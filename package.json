{
  "name": "app",
  "version": "1.0.0",
  "description": "Cohabitat Club Cyclistes",
  "main": "bim.js",
  "scripts": {
    "validate:allocations": "node validate-allocations.js allocations.json",
    "lint": "eslint .",
    "test": "playwright test",
    "test:unit": "node --test tests/*.test.js",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:coverage": "c8 --all --include='*.js' --exclude='scripts/archive/**' --exclude='bim.js' --exclude='playwright.config.js' --exclude='eslint.config.mjs' node --test tests/*.test.js",
    "dev": "http-server . -p 8080"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rngadam/cohabitat.cc.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rngadam/cohabitat.cc/issues"
  },
  "homepage": "https://github.com/rngadam/cohabitat.cc#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "playwright": "^1.59.1",
    "stylelint-config-recommended": "^17.0.0"
  }
}
